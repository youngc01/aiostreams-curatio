{
  "id": "stremio-custom-source",
  "name": "Stremio Catalog",
  "version": "0.9.0",
  "manifestURI": "",
  "language": "typescript",
  "type": "custom-source",
  "description": "Exposes a Stremio addon catalog as a Seanime custom source. Intended to be paired with an AIOStreams stream provider.",
  "author": "Viren070",
  "icon": "https://raw.githubusercontent.com/Stremio/stremio-brand/refs/heads/master/logos/PNG/stremio-logo-800px.png",
  "lang": "multi",
  "payloadURI": "",
  "isDevelopment": true,
  "notes": "For an easier, guided setup to batch import all catalogs from a Stremio addon, install this via AIOStreams' configuration page instead. See the documentation for more details.",
  "website": "https://docs.aiostreams.viren070.me",
  "readme": "https://docs.aiostreams.viren070.me/guides/seanime",
  "userConfig": {
    "requiresConfig": true,
    "version": 1,
    "fields": [
      {
        "name": "manifestUrl",
        "label": "Stremio Addon Manifest URL",
        "type": "text",
        "default": ""
      },
      {
        "name": "catalogType",
        "label": "Catalog Type",
        "type": "text",
        "default": ""
      },
      {
        "name": "catalogId",
        "label": "Catalog ID",
        "type": "text",
        "default": ""
      }
    ]
  }
}